&ACCESS RVP
&REL 48
def motion_eki()
   ; Software License Agreement (BSD License)
   ;
   ; Copyright (c) 2018, 3M
   ; Modifications copyright (c) 2021 Gergely Sóti
   ; All rights reserved.
   ;
